<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SignupApp.ViewModels"
             x:Class="SignupApp.VIews.SignupPage"
             Title="Sign Up">

    <ContentPage.BindingContext>
        <vm:SignupViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="16" VerticalOptions="Center">

            <Label Text="Create Account"
                   FontSize="28" FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#333"/>

            <Label Text="Join us today!" FontSize="14"
                   HorizontalOptions="Center" TextColor="#888"
                   Margin="0,0,0,10"/>

            <!-- Username -->
            <Frame BorderColor="#ddd" CornerRadius="10" Padding="5" HasShadow="False">
                <Entry Placeholder="Username"
                       Text="{Binding Username}"
                       PlaceholderColor="#aaa"/>
            </Frame>

            <!-- Email -->
            <Frame BorderColor="#ddd" CornerRadius="10" Padding="5" HasShadow="False">
                <Entry Placeholder="Email Address"
                       Text="{Binding Email}"
                       Keyboard="Email"
                       PlaceholderColor="#aaa"/>
            </Frame>

            <!-- Password -->
            <Frame BorderColor="#ddd" CornerRadius="10" Padding="5" HasShadow="False">
                <Entry Placeholder="Password"
                       Text="{Binding Password}"
                       IsPassword="True"
                       PlaceholderColor="#aaa"/>
            </Frame>

            <!-- Confirm Password -->
            <Frame BorderColor="#ddd" CornerRadius="10" Padding="5" HasShadow="False">
                <Entry Placeholder="Confirm Password"
                       Text="{Binding ConfirmPassword}"
                       IsPassword="True"
                       PlaceholderColor="#aaa"/>
            </Frame>

            <!-- Error Message -->
            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red" FontSize="13"
                   HorizontalOptions="Center"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}"/>

            <!-- Sign Up Button -->
            <Button Text="Sign Up"
                    Command="{Binding SignUpCommand}"
                    BackgroundColor="#6C63FF"
                    TextColor="White"
                    CornerRadius="10"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    Margin="0,10,0,0"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>